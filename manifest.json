{
  "manifest_version": 3,
  "name": "IPOK — IP 纯净度 / 风险检测",
  "version": "1.0.1",
  "description": "一键查看当前线路 IP 的纯净度/风险值、原生IP、机房判定、AI 可用性。Powered by ipok.io",
  "action": {
    "default_popup": "popup.html",
    "default_title": "IPOK — 检测当前 IP",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [],
  "host_permissions": ["https://ipok.io/*"]
}
